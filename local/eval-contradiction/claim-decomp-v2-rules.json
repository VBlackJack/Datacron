  "value_patterns": [
    "\\b(?:aes|rsa)[-_ ]?\\d{3,4}(?:[-_ ]?(?:cbc|gcm|oaep))?\\b",
    "\\bnet\\d+(?:\\.\\d+)?(?:-windows)?\\b",
    "\\b(?:port|vncport)\\s*[:=]?\\s*\\d{1,5}\\b",
    "\\b(?:zero|one|two|three|four|five|six|seven|eight|nine|ten|twelve|single|multiple|unique)\\b",
    "\\b\\d{1,3}\\s*(?:collections?|sections?|mismatches?|divergences?|certificates?|credentials?)\\b",
    "\\bmismatch\\s*[:=]?\\s*\\d{1,4}\\b"
  ],
  "hardening_rules": [
    {
      "id": "longest-alias-first",
      "justification": "Les modaux composés comme 'ne doit pas' doivent être normalisés avant leurs sous-termes positifs."
    },
    {
      "id": "deontic-tristate",
      "justification": "Obligation, interdiction et permission sont des polarités distinctes applicables à toute règle ou politique."
    },
    {
      "id": "exclusive-vs-concurrent",
      "justification": "L'exclusivité et l'exécution concurrente sont des états incompatibles d'une même politique d'accès."
    },
    {
      "id": "revision-lifecycle",
      "justification": "Faux/corrigé/résolu/re-déféré/livré décrivent des révisions d'état générales, sans dépendre d'une note."
    },
    {
      "id": "storage-form-and-authority",
      "justification": "Fichier plat, magasin, Markdown canonique et store dérivé sont des choix d'état incompatibles récurrents."
    },
    {
      "id": "cardinality-and-keyed-values",
      "justification": "Les cardinalités et valeurs numériques divergentes sur le même champ sont des conflits génériques."
    },
    {
      "id": "frontmatter-supersedes-context",
      "justification": "Une relation supersedes autorise un appariement plus sensible, mais seulement si des claims sémantiques divergent."
    }
  ]
